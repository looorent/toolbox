{
  "name": "toolbox",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "build-only": "vite build",
    "build": "pnpm run cf-typegen && pnpm run type-check && pnpm run build-only",
    "preview": "pnpm run build && wrangler dev",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:gen": "dotenv -e .dev.vars -- drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:reset": "npm run clean:d1 && npm run db:migrate:local",
    "db:studio:local": "DB_PATH=$(find .wrangler/state/v3/d1 -name '*.sqlite' | head -n 1) && export DB_PATH && echo \"Connecting to $DB_PATH\" && npx drizzle-kit studio --config drizzle.local.config.ts",
    "db:studio:prod": "dotenv -e .dev.vars -- drizzle-kit studio --config drizzle.prod.config.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "clean": "rm -rf .wrangler dist build node_modules/.cache",
    "clean:d1": "rm -rf .wrangler/state/v3/d1"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.1",
    "anpr-wiegand": "1.0.2",
    "colord": "2.9.3",
    "drizzle-orm": "0.45.1",
    "he": "1.2.0",
    "jsonrepair": "3.13.2",
    "qr-scanner": "1.4.2",
    "qrcode": "1.5.4",
    "tailwindcss": "4.2.1",
    "valibot": "1.2.0",
    "vue": "3.5.29",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@cloudflare/vite-plugin": "1.25.4",
    "@tsconfig/node24": "24.0.4",
    "@types/he": "1.2.3",
    "@types/node": "25.3.0",
    "@types/qrcode": "1.5.6",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/tsconfig": "0.8.1",
    "better-sqlite3": "12.6.2",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.9",
    "jsdom": "28.1.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-vue-devtools": "8.0.6",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5",
    "wrangler": "4.68.0"
  }
}
